# ═══════════════════════════════════════════
# NetSave Backend — Environment Variables
# Copy this to .env and fill in real values
# ═══════════════════════════════════════════

# ── Server ──
PORT=3000
NODE_ENV=production

# ── Firebase Admin SDK ──
# Download service account key from Firebase Console:
# Project Settings → Service Accounts → Generate New Private Key
FIREBASE_PROJECT_ID=netsave-app
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@netsave-app.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----"

# ── Puppeteer ──
# Max concurrent browser pages (Oracle Free: 1GB RAM → keep low)
PUPPETEER_MAX_PAGES=3
PUPPETEER_TIMEOUT_MS=15000
PUPPETEER_NAVIGATION_TIMEOUT_MS=20000

# ── Compression ──
IMAGE_QUALITY=40
IMAGE_MAX_WIDTH=800
IMAGE_MAX_HEIGHT=600

# ── Rate Limiting ──
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

# ── CORS ──
ALLOWED_ORIGINS=http://localhost:8081,https://netsave.app

# ── Logging ──
LOG_LEVEL=info
